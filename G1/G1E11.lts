set Ts = {tA}
const Z = 2

CINTA = (agregar[x:Ts] -> extraer1[x] -> CINTA).

BRAZO1 = (extraer1 -> enPrensa -> BRAZO1).

PRENSA = (enPrensa -> extraer2 -> PRENSA).

BRAZO2 = (extraer2 -> enSalida -> BRAZO2).

SALIDA = (enSalida -> SALIDA).

||CELULA = ([1..Z]:CINTA || BRAZO1 || PRENSA || BRAZO2 || SALIDA)/{
agregar/[1].agregar,
[i:2..Z].agregar/[i-1].extraer1,
extraer1/[Z].extraer1[Ts]
}@{agregar, extraer1, extraer2}.
